// API endpoint para enviar correos de notificación cuando hay un reporte nuevo.
// Requiere la variable de entorno RESEND_API_KEY configurada en Vercel.
// Si no está configurada, silenciosamente no hace nada (no rompe el flujo).

export const runtime = 'nodejs';

export async function POST(req) {
  try {
    const apiKey = process.env.RESEND_API_KEY;
    if (!apiKey) {
      // Fallar silenciosamente: el reporte ya se guardó en DB, el correo es extra
      return Response.json({ enviado: false, motivo: 'RESEND_API_KEY no configurada' });
    }

    const body = await req.json();
    const { destinatarios, asunto, html } = body;

    if (!destinatarios || !destinatarios.length) {
      return Response.json({ enviado: false, motivo: 'Sin destinatarios' });
    }

    // Filtrar emails válidos
    const emails = destinatarios.filter(e => e && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e));
    if (!emails.length) {
      return Response.json({ enviado: false, motivo: 'Sin emails válidos' });
    }

    // Remitente por defecto del sandbox de Resend
    const from = process.env.RESEND_FROM || 'Super Techos <onboarding@resend.dev>';

    const resp = await fetch('https://api.resend.com/emails', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${apiKey}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        from,
        to: emails,
        subject: asunto || 'Reporte de obra - Super Techos',
        html: html || '<p>Nuevo reporte.</p>',
      }),
    });

    const data = await resp.json();
    if (!resp.ok) {
      console.error('Resend error:', data);
      return Response.json({ enviado: false, motivo: data?.message || 'Error Resend' }, { status: 200 });
    }

    return Response.json({ enviado: true, id: data.id });
  } catch (e) {
    console.error('Error enviando correo:', e);
    return Response.json({ enviado: false, motivo: e.message }, { status: 200 });
  }
}
